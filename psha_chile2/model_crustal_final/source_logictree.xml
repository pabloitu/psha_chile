<?xml version="1.0" encoding="UTF-8"?>
<nrml xmlns:gml="http://www.opengis.net/gml"
      xmlns="http://openquake.org/xmlns/nrml/0.4">
    <logicTree logicTreeID="lt_ssm">
        <logicTreeBranchingLevel branchingLevelID="bl1">
            <logicTreeBranchSet uncertaintyType="sourceModel"
                                branchSetID="bs_ssm">

                <!-- Fault branches: capped crustal SSM (M < 6 inside the fault
                     buffers) + one fault MFD model each. -->
                <logicTreeBranch branchID="al1">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources.xml
                        crustal_faults_al1.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>
                <logicTreeBranch branchID="al2">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources.xml
                        crustal_faults_al2.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>
                <logicTreeBranch branchID="al3">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources.xml
                        crustal_faults_al3.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>
                <logicTreeBranch branchID="yc">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources.xml
                        crustal_faults_yc.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>
                <logicTreeBranch branchID="wc_scaling">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources.xml
                        crustal_faults_reference.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>

                <!-- Baseline: crustal seismicity with NO fault model. Uses the
                     UNCAPPED crustal SSM (s05), which keeps M up to each
                     class Mmax everywhere. Using the capped grid here would
                     leave a hole with no M>=6 inside the fault buffers. -->
                <logicTreeBranch branchID="nofaults">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                        ssm_crustal_point_sources_nofaults.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.14285714285714285</uncertaintyWeight>
                </logicTreeBranch>

                <!-- Subduction only: no crustal seismicity at all. -->
                <logicTreeBranch branchID="subduction_only">
                    <uncertaintyModel>
                        subduction_interface_sources.xml
                        ssm_intraslab_point_sources.xml
                    </uncertaintyModel>
                    <uncertaintyWeight>0.1428571428571429</uncertaintyWeight>
                </logicTreeBranch>

            </logicTreeBranchSet>
        </logicTreeBranchingLevel>
    </logicTree>
</nrml>